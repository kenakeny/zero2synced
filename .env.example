# ── Backend (.env) ─────────────────────────────────────────────────────────
# Copy to `.env` for local dev. In production set these with `fly secrets set`.

# --- LLM: Gemini Developer API (API key path, NOT Vertex/ADC) ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_API_KEY=                 # from https://aistudio.google.com/apikey
# GEMINI_MODEL=gemini-3-pro-preview   # optional override (default set in code)

# --- Database (Neon Postgres) ---
DATABASE_URL=                   # postgresql://user:pass@host/db?sslmode=require

# --- Auth / encryption ---
JWT_SECRET=                     # long random string; signs JWTs + derives the
                                # Fivetran-credential encryption key
# FERNET_KEY=                   # optional: explicit Fernet key (else derived from JWT_SECRET)

# --- Uploads (optional) ---
# S3_BUCKET=                    # leave unset to keep uploads context-only (no S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=

# Per-user Fivetran keys are entered in the app and stored encrypted in the DB,
# so they are NOT configured here. (The CLI in main.py still reads FIVETRAN_API_KEY
# / FIVETRAN_API_SECRET from .env for local terminal testing.)
